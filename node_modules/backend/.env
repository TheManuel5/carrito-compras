# =============================================
# VARIABLES DE ENTORNO - CARRITO DE COMPRAS
# Copiar este archivo como .env y configurar
# =============================================

# Servidor
NODE_ENV=development
PORT=3001

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://postgres@localhost:5432/carrito_compras?schema=public"

# JWT
JWT_SECRET=tu_super_secreto_jwt_aqui_cambiar_en_produccion
JWT_REFRESH_SECRET=tu_super_secreto_refresh_jwt_aqui_cambiar
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM="Carrito de Compras <noreply@carritocompras.com>"

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Stripe (Opcional - Pasarela de Pagos)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log
