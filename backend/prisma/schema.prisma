// =============================================
// SCHEMA PRISMA - SISTEMA CARRITO DE COMPRAS
// Motor: PostgreSQL 16+
// Convención: snake_case en español
// =============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// SEGURIDAD Y TRANSVERSALES
// ============================

model seg_roles {
  id          Int               @id @default(autoincrement())
  nombre      String            @unique @db.VarChar(50)
  descripcion String?           @db.VarChar(255)
  activo      Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  usuarios    seg_usuario_rol[]
  permisos    seg_rol_permiso[]
}

model seg_permisos {
  id          Int               @id @default(autoincrement())
  modulo      String            @db.VarChar(50)
  accion      String            @db.VarChar(50)
  descripcion String?           @db.VarChar(255)
  created_at  DateTime          @default(now())
  roles       seg_rol_permiso[]

  @@unique([modulo, accion])
}

model seg_rol_permiso {
  id         Int          @id @default(autoincrement())
  rol_id     Int
  permiso_id Int
  created_at DateTime     @default(now())
  rol        seg_roles    @relation(fields: [rol_id], references: [id], onDelete: Cascade)
  permiso    seg_permisos @relation(fields: [permiso_id], references: [id], onDelete: Cascade)

  @@unique([rol_id, permiso_id])
}

model seg_usuarios {
  id                   Int               @id @default(autoincrement())
  email                String            @unique @db.VarChar(255)
  nombre               String            @db.VarChar(100)
  apellido             String            @db.VarChar(100)
  password_hash        String            @db.VarChar(255)
  telefono             String?           @db.VarChar(20)
  email_verificado     Boolean           @default(false)
  token_verificacion   String?           @db.VarChar(255)
  token_recuperacion   String?           @db.VarChar(255)
  token_exp_recuperacion DateTime?
  refresh_token        String?           @db.Text
  refresh_token_exp    DateTime?
  activo               Boolean           @default(true)
  ultimo_login         DateTime?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  roles                seg_usuario_rol[]
  carritos             ord_carritos[]
  ordenes              ord_ordenes[]
  auditoria            auditoria_registro[]
  cliente              cli_clientes?
}

model seg_usuario_rol {
  id         Int          @id @default(autoincrement())
  usuario_id Int
  rol_id     Int
  created_at DateTime     @default(now())
  usuario    seg_usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  rol        seg_roles    @relation(fields: [rol_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, rol_id])
}

model auditoria_registro {
  id               Int          @id @default(autoincrement())
  usuario_id       Int?
  accion           String       @db.VarChar(50)
  modulo           String       @db.VarChar(50)
  tabla            String?      @db.VarChar(100)
  registro_id      Int?
  datos_anteriores Json?
  datos_nuevos     Json?
  ip               String?      @db.VarChar(45)
  created_at       DateTime     @default(now())
  usuario          seg_usuarios? @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
}

// ============================
// CONFIGURACIÓN DEL SISTEMA
// ============================

model configuracion_sistema {
  id        Int      @id @default(autoincrement())
  clave     String   @unique @db.VarChar(100)
  valor     String   @db.Text
  tipo      String   @db.VarChar(20) // string, number, boolean, json
  descripcion String? @db.VarChar(255)
  updated_at DateTime @updatedAt
}

model monedas {
  id         Int      @id @default(autoincrement())
  codigo     String   @unique @db.VarChar(3)
  nombre     String   @db.VarChar(50)
  simbolo    String   @db.VarChar(5)
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  tipo_cambio tipo_cambio[]
}

model tipo_cambio {
  id         Int      @id @default(autoincrement())
  moneda_id  Int
  tasa       Decimal  @db.Decimal(15, 6)
  fecha      DateTime @default(now())
  moneda     monedas  @relation(fields: [moneda_id], references: [id])
}

// ============================
// CATÁLOGO DE PRODUCTOS
// ============================

model cat_categorias {
  id           Int                  @id @default(autoincrement())
  nombre       String               @db.VarChar(100)
  descripcion  String?              @db.Text
  imagen_url   String?              @db.VarChar(500)
  activo       Boolean              @default(true)
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt
  subcategorias cat_subcategorias[]
  productos    cat_productos[]
}

model cat_subcategorias {
  id           Int            @id @default(autoincrement())
  categoria_id Int
  nombre       String         @db.VarChar(100)
  descripcion  String?        @db.Text
  imagen_url   String?        @db.VarChar(500)
  activo       Boolean        @default(true)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  categoria    cat_categorias @relation(fields: [categoria_id], references: [id], onDelete: Cascade)
  productos    cat_productos[]
}

model cat_marcas {
  id          Int             @id @default(autoincrement())
  nombre      String          @unique @db.VarChar(100)
  descripcion String?         @db.Text
  logo_url    String?         @db.VarChar(500)
  activo      Boolean         @default(true)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  productos   cat_productos[]
}

model cat_unidades_medida {
  id         Int             @id @default(autoincrement())
  nombre     String          @unique @db.VarChar(50)
  simbolo    String          @db.VarChar(10)
  created_at DateTime        @default(now())
  productos  cat_productos[]
}

model cat_etiquetas {
  id         Int                    @id @default(autoincrement())
  nombre     String                 @unique @db.VarChar(50)
  color      String?                @db.VarChar(7)
  created_at DateTime               @default(now())
  productos  cat_producto_etiqueta[]
}

model cat_atributos {
  id         Int                      @id @default(autoincrement())
  nombre     String                   @unique @db.VarChar(100)
  tipo       String                   @db.VarChar(20) // texto, numero, color, etc.
  created_at DateTime                 @default(now())
  valores    cat_valores_atributo[]
}

model cat_valores_atributo {
  id           Int                      @id @default(autoincrement())
  atributo_id  Int
  valor        String                   @db.VarChar(100)
  created_at   DateTime                 @default(now())
  atributo     cat_atributos            @relation(fields: [atributo_id], references: [id], onDelete: Cascade)
  productos    cat_producto_atributo[]
}

model cat_productos {
  id                  Int                       @id @default(autoincrement())
  sku                 String                    @unique @db.VarChar(50)
  nombre              String                    @db.VarChar(255)
  descripcion_corta   String?                   @db.VarChar(500)
  descripcion_larga   String?                   @db.Text
  categoria_id        Int
  subcategoria_id     Int?
  marca_id            Int?
  unidad_medida_id    Int?
  precio_costo        Decimal                   @db.Decimal(10, 2)
  precio_venta        Decimal                   @db.Decimal(10, 2)
  precio_oferta       Decimal?                  @db.Decimal(10, 2)
  fecha_inicio_oferta DateTime?
  fecha_fin_oferta    DateTime?
  peso                Decimal?                  @db.Decimal(10, 3)
  alto                Decimal?                  @db.Decimal(10, 2)
  ancho               Decimal?                  @db.Decimal(10, 2)
  largo               Decimal?                  @db.Decimal(10, 2)
  estado              String                    @default("activo") @db.VarChar(20) // activo, inactivo, borrador
  destacado           Boolean                   @default(false)
  nuevo               Boolean                   @default(false)
  activo              Boolean                   @default(true)
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  created_by          Int?
  updated_by          Int?
  categoria           cat_categorias            @relation(fields: [categoria_id], references: [id])
  subcategoria        cat_subcategorias?        @relation(fields: [subcategoria_id], references: [id])
  marca               cat_marcas?               @relation(fields: [marca_id], references: [id])
  unidad_medida       cat_unidades_medida?      @relation(fields: [unidad_medida_id], references: [id])
  imagenes            cat_imagenes_producto[]
  atributos           cat_producto_atributo[]
  etiquetas           cat_producto_etiqueta[]
  stock               inv_stock_producto?
  items_carrito       ord_items_carrito[]
  items_orden         ord_items_orden[]
  lista_deseos        cli_items_lista_deseos[]
  resenas             cli_resenas_producto[]
  historial_nav       cli_historial_navegacion[]

  @@index([nombre])
  @@index([sku])
  @@index([categoria_id])
  @@index([estado])
}

model cat_imagenes_producto {
  id          Int           @id @default(autoincrement())
  producto_id Int
  url         String        @db.VarChar(500)
  alt         String?       @db.VarChar(255)
  orden       Int           @default(0)
  es_principal Boolean      @default(false)
  created_at  DateTime      @default(now())
  producto    cat_productos @relation(fields: [producto_id], references: [id], onDelete: Cascade)
}

model cat_producto_atributo {
  id                  Int                  @id @default(autoincrement())
  producto_id         Int
  valor_atributo_id   Int
  created_at          DateTime             @default(now())
  producto            cat_productos        @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  valor_atributo      cat_valores_atributo @relation(fields: [valor_atributo_id], references: [id], onDelete: Cascade)

  @@unique([producto_id, valor_atributo_id])
}

model cat_producto_etiqueta {
  id           Int           @id @default(autoincrement())
  producto_id  Int
  etiqueta_id  Int
  created_at   DateTime      @default(now())
  producto     cat_productos @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  etiqueta     cat_etiquetas @relation(fields: [etiqueta_id], references: [id], onDelete: Cascade)

  @@unique([producto_id, etiqueta_id])
}

// ============================
// INVENTARIO
// ============================

model inv_stock_producto {
  id             Int           @id @default(autoincrement())
  producto_id    Int           @unique
  cantidad       Int           @default(0)
  cantidad_min   Int           @default(5)
  cantidad_reservada Int       @default(0)
  updated_at     DateTime      @updatedAt
  producto       cat_productos @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  movimientos    inv_movimientos_inventario[]
}

model inv_movimientos_inventario {
  id             Int                @id @default(autoincrement())
  stock_id       Int
  tipo           String             @db.VarChar(20) // entrada, salida, ajuste, reserva, liberacion
  cantidad       Int
  cantidad_antes Int
  cantidad_despues Int
  motivo         String?            @db.VarChar(255)
  referencia_id  Int?               // orden_id, ajuste_id, etc.
  referencia_tipo String?           @db.VarChar(50)
  usuario_id     Int?
  created_at     DateTime           @default(now())
  stock          inv_stock_producto @relation(fields: [stock_id], references: [id])
}

model inv_proveedores {
  id            Int                    @id @default(autoincrement())
  nombre        String                 @db.VarChar(255)
  ruc           String?                @db.VarChar(20)
  email         String?                @db.VarChar(255)
  telefono      String?                @db.VarChar(20)
  direccion     String?                @db.Text
  contacto      String?                @db.VarChar(100)
  activo        Boolean                @default(true)
  created_at    DateTime               @default(now())
  updated_at    DateTime               @updatedAt
  ordenes_compra inv_ordenes_compra[]
}

model inv_ordenes_compra {
  id             Int                       @id @default(autoincrement())
  proveedor_id   Int
  numero_orden   String                    @unique @db.VarChar(50)
  estado         String                    @default("pendiente") @db.VarChar(20)
  total          Decimal                   @db.Decimal(10, 2)
  fecha_esperada DateTime?
  notas          String?                   @db.Text
  created_at     DateTime                  @default(now())
  updated_at     DateTime                  @updatedAt
  proveedor      inv_proveedores           @relation(fields: [proveedor_id], references: [id])
  detalles       inv_detalle_orden_compra[]
  recepciones    inv_recepciones[]
}

model inv_detalle_orden_compra {
  id               Int                @id @default(autoincrement())
  orden_compra_id  Int
  producto_id      Int
  cantidad         Int
  precio_unitario  Decimal            @db.Decimal(10, 2)
  subtotal         Decimal            @db.Decimal(10, 2)
  orden_compra     inv_ordenes_compra @relation(fields: [orden_compra_id], references: [id], onDelete: Cascade)
}

model inv_recepciones {
  id               Int                @id @default(autoincrement())
  orden_compra_id  Int
  fecha_recepcion  DateTime           @default(now())
  notas            String?            @db.Text
  usuario_id       Int?
  created_at       DateTime           @default(now())
  orden_compra     inv_ordenes_compra @relation(fields: [orden_compra_id], references: [id])
}

model inv_ajustes {
  id          Int                    @id @default(autoincrement())
  motivo      String                 @db.VarChar(255)
  usuario_id  Int?
  created_at  DateTime               @default(now())
  detalles    inv_detalle_ajuste[]
}

model inv_detalle_ajuste {
  id          Int         @id @default(autoincrement())
  ajuste_id   Int
  producto_id Int
  cantidad    Int
  ajuste      inv_ajustes @relation(fields: [ajuste_id], references: [id], onDelete: Cascade)
}

// ============================
// CLIENTES
// ============================

model cli_clientes {
  id                Int                       @id @default(autoincrement())
  usuario_id        Int                       @unique
  dni               String?                   @db.VarChar(20)
  fecha_nacimiento  DateTime?
  genero            String?                   @db.VarChar(10)
  total_compras     Decimal                   @default(0) @db.Decimal(15, 2)
  num_ordenes       Int                       @default(0)
  ultima_compra     DateTime?
  segmento          String                    @default("nuevo") @db.VarChar(20) // nuevo, recurrente, inactivo, vip
  activo            Boolean                   @default(true)
  created_at        DateTime                  @default(now())
  updated_at        DateTime                  @updatedAt
  usuario           seg_usuarios              @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  direcciones       cli_direcciones[]
  lista_deseos      cli_lista_deseos?
  resenas           cli_resenas_producto[]
  historial_nav     cli_historial_navegacion[]
}

model cli_direcciones {
  id            Int           @id @default(autoincrement())
  cliente_id    Int
  nombre        String        @db.VarChar(100)
  apellido      String        @db.VarChar(100)
  direccion     String        @db.VarChar(500)
  ciudad        String        @db.VarChar(100)
  departamento  String        @db.VarChar(100)
  codigo_postal String?       @db.VarChar(10)
  telefono      String        @db.VarChar(20)
  es_principal  Boolean       @default(false)
  activo        Boolean       @default(true)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  cliente       cli_clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  ordenes       ord_ordenes[]
}

model cli_lista_deseos {
  id         Int                      @id @default(autoincrement())
  cliente_id Int                      @unique
  created_at DateTime                 @default(now())
  updated_at DateTime                 @updatedAt
  cliente    cli_clientes             @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  items      cli_items_lista_deseos[]
}

model cli_items_lista_deseos {
  id             Int              @id @default(autoincrement())
  lista_deseos_id Int
  producto_id    Int
  created_at     DateTime         @default(now())
  lista_deseos   cli_lista_deseos @relation(fields: [lista_deseos_id], references: [id], onDelete: Cascade)
  producto       cat_productos    @relation(fields: [producto_id], references: [id], onDelete: Cascade)

  @@unique([lista_deseos_id, producto_id])
}

model cli_resenas_producto {
  id           Int           @id @default(autoincrement())
  cliente_id   Int
  producto_id  Int
  calificacion Int
  titulo       String?       @db.VarChar(255)
  comentario   String?       @db.Text
  aprobada     Boolean       @default(false)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  cliente      cli_clientes  @relation(fields: [cliente_id], references: [id])
  producto     cat_productos @relation(fields: [producto_id], references: [id])

  @@unique([cliente_id, producto_id])
}

model cli_historial_navegacion {
  id          Int           @id @default(autoincrement())
  cliente_id  Int
  producto_id Int
  visited_at  DateTime      @default(now())
  cliente     cli_clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  producto    cat_productos @relation(fields: [producto_id], references: [id], onDelete: Cascade)
}

// ============================
// CARRITO Y ÓRDENES
// ============================

model ord_carritos {
  id          Int                 @id @default(autoincrement())
  usuario_id  Int?
  session_id  String?             @db.VarChar(255)
  estado      String              @default("activo") @db.VarChar(20)
  expires_at  DateTime?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  usuario     seg_usuarios?       @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  items       ord_items_carrito[]

  @@index([usuario_id])
  @@index([session_id])
}

model ord_items_carrito {
  id          Int           @id @default(autoincrement())
  carrito_id  Int
  producto_id Int
  cantidad    Int
  precio      Decimal       @db.Decimal(10, 2)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  carrito     ord_carritos  @relation(fields: [carrito_id], references: [id], onDelete: Cascade)
  producto    cat_productos @relation(fields: [producto_id], references: [id])

  @@unique([carrito_id, producto_id])
}

model ord_metodos_envio {
  id              Int           @id @default(autoincrement())
  nombre          String        @db.VarChar(100)
  descripcion     String?       @db.VarChar(255)
  precio          Decimal       @db.Decimal(10, 2)
  dias_estimados  Int
  activo          Boolean       @default(true)
  created_at      DateTime      @default(now())
  ordenes         ord_ordenes[]
}

model ord_estados_orden {
  id          Int                    @id @default(autoincrement())
  nombre      String                 @unique @db.VarChar(50)
  descripcion String?                @db.VarChar(255)
  orden       Int                    @default(0)
  historial   ord_historial_estados[]
}

model ord_ordenes {
  id                  Int                    @id @default(autoincrement())
  numero_orden        String                 @unique @db.VarChar(20)
  usuario_id          Int?
  direccion_envio_id  Int?
  metodo_envio_id     Int?
  estado              String                 @default("pendiente_pago") @db.VarChar(30)
  subtotal            Decimal                @db.Decimal(10, 2)
  igv                 Decimal                @db.Decimal(10, 2)
  costo_envio         Decimal                @default(0) @db.Decimal(10, 2)
  descuento           Decimal                @default(0) @db.Decimal(10, 2)
  total               Decimal                @db.Decimal(10, 2)
  codigo_cupon        String?                @db.VarChar(50)
  notas               String?                @db.Text
  numero_tracking     String?                @db.VarChar(100)
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  usuario             seg_usuarios?          @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  direccion_envio     cli_direcciones?       @relation(fields: [direccion_envio_id], references: [id])
  metodo_envio        ord_metodos_envio?     @relation(fields: [metodo_envio_id], references: [id])
  items               ord_items_orden[]
  pagos               ord_pagos[]
  historial_estados   ord_historial_estados[]

  @@index([numero_orden])
  @@index([usuario_id])
  @@index([estado])
  @@index([created_at])
}

model ord_items_orden {
  id              Int           @id @default(autoincrement())
  orden_id        Int
  producto_id     Int?
  nombre_producto String        @db.VarChar(255)
  sku             String        @db.VarChar(50)
  cantidad        Int
  precio_unitario Decimal       @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)
  orden           ord_ordenes   @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  producto        cat_productos? @relation(fields: [producto_id], references: [id], onDelete: SetNull)
}

model ord_pagos {
  id               Int                       @id @default(autoincrement())
  orden_id         Int
  metodo           String                    @db.VarChar(50) // stripe, transferencia, contra_entrega
  estado           String                    @default("pendiente") @db.VarChar(20)
  monto            Decimal                   @db.Decimal(10, 2)
  moneda           String                    @default("PEN") @db.VarChar(3)
  referencia_ext   String?                   @db.VarChar(255)
  created_at       DateTime                  @default(now())
  updated_at       DateTime                  @updatedAt
  orden            ord_ordenes               @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  transacciones    ord_transacciones_pago[]
}

model ord_transacciones_pago {
  id            Int       @id @default(autoincrement())
  pago_id       Int
  tipo          String    @db.VarChar(30) // cobro, reembolso, disputa
  estado        String    @db.VarChar(20)
  monto         Decimal   @db.Decimal(10, 2)
  respuesta_ext String?   @db.Text
  created_at    DateTime  @default(now())
  pago          ord_pagos @relation(fields: [pago_id], references: [id], onDelete: Cascade)
}

model ord_historial_estados {
  id          Int               @id @default(autoincrement())
  orden_id    Int
  estado_id   Int?
  estado      String            @db.VarChar(30)
  comentario  String?           @db.Text
  usuario_id  Int?
  created_at  DateTime          @default(now())
  orden       ord_ordenes       @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  estado_ref  ord_estados_orden? @relation(fields: [estado_id], references: [id])

  @@index([orden_id])
}
